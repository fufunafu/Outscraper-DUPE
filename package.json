{
  "name": "outscraper-dupe",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node --experimental-strip-types --no-warnings apps/desktop/src/main.ts",
    "test": "node --experimental-strip-types --test packages/engine/src/**/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "package": "bash apps/desktop/package-app.sh"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "undici": "^8.8.0"
  }
}
